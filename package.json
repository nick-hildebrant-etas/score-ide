{
  "name": "score-ide",
  "displayName": "score-ide",
  "description": "Score IDE - Dagger pipeline manager for Scorenado",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "score-ide-sidebar",
          "title": "score",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "score-ide-sidebar": [
        {
          "id": "score-ide.pipelinesView",
          "name": "Dagger Pipelines",
          "icon": "media/icon.svg"
        },
        {
          "id": "score-ide.servicesView",
          "name": "Services",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "score-ide.runPipeline",
        "title": "Run Pipeline",
        "icon": "$(play)"
      },
      {
        "command": "score-ide.refreshPipelines",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "score-ide.startService",
        "title": "Start Service",
        "icon": "$(debug-start)"
      },
      {
        "command": "score-ide.stopService",
        "title": "Stop Service",
        "icon": "$(debug-stop)"
      },
      {
        "command": "score-ide.refreshServices",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "score-ide.openServiceBrowser",
        "title": "Open in Browser Preview",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "score-ide.runPipeline",
          "when": "view == score-ide.pipelinesView && viewItem == pipeline",
          "group": "inline"
        },
        {
          "command": "score-ide.startService",
          "when": "view == score-ide.servicesView && viewItem == service-stopped",
          "group": "inline"
        },
        {
          "command": "score-ide.stopService",
          "when": "view == score-ide.servicesView && viewItem == service-running",
          "group": "inline"
        },
        {
          "command": "score-ide.openServiceBrowser",
          "when": "view == score-ide.servicesView && viewItem == service-running",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "score-ide.refreshPipelines",
          "when": "view == score-ide.pipelinesView",
          "group": "navigation"
        },
        {
          "command": "score-ide.refreshServices",
          "when": "view == score-ide.servicesView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "score",
      "properties": {
        "score-ide.pipelinesDir": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path **relative to the workspace root** containing `dagger.json`. Leave empty to use the workspace root."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "postinstall": "cd pipelines && dagger develop",
    "compile": "rm -rf out && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint && tsc -p pipelines/tsconfig.json --noEmit",
    "test:suite": "vscode-test",
    "lint": "eslint . && tsc --noEmit",
    "clean": "git diff --quiet && git diff --cached --quiet || (echo 'Worktree is dirty — commit or stash changes first' >&2 && exit 1) && git clean -fdx",
    "test": "mocha --ui tdd --timeout 1 'out/test/unit/**/*.test.js'"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.14.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "typescript": "^5.7.2"
  }
}
